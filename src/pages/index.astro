---
import Layout from '../layouts/Layout.astro';
import {
  profile,
  stats,
  research,
  publications,
  publicationsNote,
  editorial,
  experience,
  projects,
  education,
  skills,
  interests,
} from '../data/portfolio';

const nav = [
  { href: '#research', label: 'Research' },
  { href: '#publications', label: 'Publications' },
  { href: '#editorial', label: 'Editorial' },
  { href: '#experience', label: 'Experience' },
  { href: '#education', label: 'Education' },
  { href: '#contact', label: 'Contact' },
];

const initials = profile.name
  .split(' ')
  .map((n) => n[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

// Social / profile links — rendered as icon buttons in the hero and contact.
const icons: Record<string, string> = {
  email:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>',
  github:
    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58l-.01-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.82 1.1.82 2.22l-.01 3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>',
  orcid:
    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zM7.37 18.16H5.62V7.98h1.75v10.18zM6.5 6.8a1.02 1.02 0 1 1 0-2.04 1.02 1.02 0 0 1 0 2.04zm11.9 11.36h-1.74v-4.97c0-1.18-.02-2.7-1.65-2.7-1.65 0-1.9 1.29-1.9 2.62v5.05h-1.74V7.98h1.67v1.39h.02c.23-.44.8-1.5 2.35-1.5 2.5 0 2.98 1.6 2.98 3.7v6.59z"/></svg>',
  ijms:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  googleScholar:
    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.84 3.77A8 8 0 0 1 12 9a8 8 0 0 1 7.16 4.27L24 9.5z"/></svg>',
};

const socialOrder: { key: keyof typeof profile.links; label: string; external: boolean }[] = [
  { key: 'email', label: 'Email', external: false },
  { key: 'linkedin', label: 'LinkedIn', external: true },
  { key: 'github', label: 'GitHub', external: true },
  { key: 'orcid', label: 'ORCID', external: true },
  { key: 'ijms', label: 'IJMS Profile', external: true },
  { key: 'googleScholar', label: 'Google Scholar', external: true },
];

const socials = socialOrder
  .map((s) => ({ ...s, href: (profile.links as Record<string, string>)[s.key] }))
  .filter((s) => s.href);
---

<Layout>
  <!-- Navbar -->
  <nav class="nav">
    <div class="nav-inner">
      <a class="nav-brand" href="#top">
        <span class="mono">{initials}</span>
        <span>{profile.name}</span>
      </a>
      <div class="nav-right">
        <ul class="nav-links">
          {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
        </ul>
        <button class="theme-toggle" type="button" aria-label="Switch to light mode">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <main id="top">
    <!-- Hero -->
    <header class="hero">
      <div class="container">
        <span class="hero-eyebrow"><span class="dot"></span>Medical Student · Researcher · Surgery Aspirant </span>
        <h1>{profile.name}</h1>
        <p class="lede">{profile.tagline}</p>
        <p class="intro">{profile.intro}</p>
        <div class="hero-meta">
          <span>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {profile.location}
          </span>
          <span>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            {profile.email}
          </span>
        </div>
        <div class="cta-row">
          <a class="btn btn-primary" href={`mailto:${profile.email}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Get in touch
          </a>
          <a class="btn btn-ghost" href="#research">View research</a>
        </div>

        <div class="social-row">
          {socials.map((s) => (
            <a
              class="social"
              href={s.href}
              aria-label={s.label}
              title={s.label}
              target={s.external ? '_blank' : undefined}
              rel={s.external ? 'noopener noreferrer' : undefined}
            >
              <Fragment set:html={icons[s.key]} />
            </a>
          ))}
        </div>

        <div class="stats">
          {stats.map((s) => (
            <div class="stat">
              <div class="value">{s.value}</div>
              <div class="label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </header>

    <!-- Research -->
    <section id="research" class="section">
      <div class="container">
        <div class="section-head">
          <span class="num">01</span>
          <h2>Research Projects</h2>
        </div>
        <div class="stack">
          {research.map((r) => (
            <article class="card reveal">
              <div class="item-head">
                <div>
                  <div class="item-title">{r.title}</div>
                  <div class="item-org">{r.org}</div>
                  {r.role && <div class="item-role">{r.role}</div>}
                </div>
                <span class="period">{r.period}</span>
              </div>
              <p class="item-desc">{r.description}</p>
              {r.contributions && (
                <div class="contrib">
                  <span class="contrib-label">Conducted</span>
                  {r.contributions.map((c) => <span class="pill">{c}</span>)}
                </div>
              )}
              <div class="tags">
                {r.status && (
                  <span class={`badge ${r.status}`}>
                    <span class="pip"></span>{r.status === 'ongoing' ? 'Ongoing' : 'Completed'}
                  </span>
                )}
                {r.tags?.map((t) => <span class="tag">{t}</span>)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Publications -->
    <section id="publications" class="section">
      <div class="container">
        <div class="section-head">
          <span class="num">02</span>
          <h2>Publications &amp; Peer Review</h2>
        </div>
        <p class="pub-note">{publicationsNote}</p>
        <div class="stack">
          {publications.map((p, i) => (
            <article class="card reveal">
              <div class="pub">
                <div class="marker">{i + 1}</div>
                <div class="body">
                  <div class="pub-title">{p.title}</div>
                  <div class="pub-meta pub-authors">{p.authors}</div>
                  <div class="pub-meta"><em>{p.journal}</em> · {p.year}</div>
                  <a class="doi-link" href={p.url} target="_blank" rel="noopener noreferrer">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    doi:{p.doi}
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Editorial -->
    <section id="editorial" class="section">
      <div class="container">
        <div class="section-head">
          <span class="num">03</span>
          <h2>Editorial &amp; Peer-Review Roles</h2>
        </div>
        <div class="grid-2">
          {editorial.map((e) => (
            <article class="card reveal">
              <div class="item-head">
                <div>
                  <div class="item-title">{e.role}</div>
                  <div class="item-org">{e.org}</div>
                </div>
                <span class="period">{e.period}</span>
              </div>
              <p class="item-desc">{e.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section id="experience" class="section">
      <div class="container">
        <div class="section-head">
          <span class="num">04</span>
          <h2>Experience &amp; Leadership</h2>
        </div>
        <div class="stack">
          {experience.map((e) => (
            <article class="card reveal">
              <div class="item-head">
                <div>
                  <div class="item-title">{e.role}</div>
                  <div class="item-org">{e.org} · {e.location}</div>
                </div>
                <span class="period">{e.period}</span>
              </div>
              <ul class="bullets">
                {e.points.map((pt) => <li>{pt}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Community Projects -->
    <section id="projects" class="section">
      <div class="container">
        <div class="section-head">
          <span class="num">05</span>
          <h2>Community &amp; Outreach Projects</h2>
        </div>
        <div class="stack">
          {projects.map((p) => (
            <article class="card reveal">
              <div class="item-head">
                <div>
                  <div class="item-title">{p.title}</div>
                  <div class="item-org">{p.org} · {p.location}</div>
                </div>
                <span class="period">{p.period}</span>
              </div>
              <ul class="bullets">
                {p.points.map((pt) => <li>{pt}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Education -->
    <section id="education" class="section">
      <div class="container">
        <div class="section-head">
          <span class="num">06</span>
          <h2>Education</h2>
        </div>
        <div class="stack">
          {education.map((ed) => (
            <article class="card reveal">
              <div class="item-head">
                <div>
                  <div class="item-title">{ed.institution}</div>
                  <div class="item-org">{ed.degree}</div>
                </div>
                <span class="period">{ed.period}</span>
              </div>
              <ul class="bullets">
                {ed.points.map((pt) => <li>{pt}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section id="skills" class="section">
      <div class="container">
        <div class="section-head">
          <span class="num">07</span>
          <h2>Skills &amp; Tools</h2>
        </div>
        <div class="grid-2">
          {skills.map((g) => (
            <article class="card skill-group reveal">
              <h3>{g.category}</h3>
              <div class="skill-items">
                {g.items.map((it) => <span>{it}</span>)}
              </div>
            </article>
          ))}
        </div>
        <div style="margin-top: 26px;">
          <h3 style="font-size: 1.02rem; margin-bottom: 12px; color: var(--accent-ink);">Beyond the lab</h3>
          <div class="interests">
            {interests.map((i) => <span>{i}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="section contact">
      <div class="container">
        <h2>Let&apos;s connect</h2>
        <p>
          Open to research collaborations, systematic reviews, and academic opportunities.
          The best way to reach me is by email.
        </p>
        <div class="contact-links">
          <a class="btn btn-primary" href={`mailto:${profile.email}`}>{profile.email}</a>
        </div>
        <div class="social-row">
          {socials.map((s) => (
            <a
              class="social"
              href={s.href}
              aria-label={s.label}
              title={s.label}
              target={s.external ? '_blank' : undefined}
              rel={s.external ? 'noopener noreferrer' : undefined}
            >
              <Fragment set:html={icons[s.key]} />
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      © {new Date().getFullYear()} {profile.name} · {profile.location} · Built with
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
    </div>
  </footer>
</Layout>
